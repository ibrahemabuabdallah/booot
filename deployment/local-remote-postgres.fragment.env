# Optional: merge these into your local .env if you want Rails on your machine
# to use the PostgreSQL instance on your VPS/Coolify.
# Uncomment and fill values. POSTGRES_HOST must reach port 5432 (VPN, SSH tunnel,
# or firewall rule); many installs keep 5432 private — then a tunnel is required.

# POSTGRES_HOST=YOUR_VPS_IP_OR_TUNNEL_HOST
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=postgres
# POSTGRES_USERNAME=postgres
# POSTGRES_PASSWORD=your_password_here
